
{
  "entities": {
    "Story": {
      "title": "Story",
      "description": "A writing project or book",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the story"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this story"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the story was created"
        },
        "status": {
          "type": "string",
          "enum": ["active", "archived", "draft"],
          "description": "Current status of the project"
        }
      },
      "required": [
        "title",
        "userId",
        "createdAt"
      ]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A chapter within a story",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the chapter"
        },
        "content": {
          "type": "string",
          "description": "The text content of the chapter"
        },
        "lastSaved": {
          "type": "string",
          "format": "date-time",
          "description": "When the chapter was last updated"
        },
        "order": {
          "type": "number",
          "description": "The display order of the chapter"
        }
      },
      "required": [
        "title",
        "content",
        "lastSaved"
      ]
    },
    "Character": {
      "title": "Character",
      "description": "A character profile within a story",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": "string" },
        "traits": { "type": "string" },
        "storyId": { "type": "string" }
      },
      "required": ["name", "storyId"]
    },
    "Location": {
      "title": "Location",
      "description": "A setting or location within a story",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "storyId": { "type": "string" }
      },
      "required": ["name", "storyId"]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Root collection for all stories"
    },
    "/stories/{storyId}/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Sub-collection of chapters for each story"
    },
    "/stories/{storyId}/characters/{characterId}": {
      "schema": "Character",
      "description": "Sub-collection of characters"
    },
    "/stories/{storyId}/locations/{locationId}": {
      "schema": "Location",
      "description": "Sub-collection of locations"
    }
  }
}
