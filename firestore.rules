
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check ownership of the parent story
    function isStoryOwner(storyId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid;
    }

    match /stories/{storyId} {
      // Users can only read/write their own stories
      allow read, write: if request.auth != null && (
        resource == null || resource.data.userId == request.auth.uid
      );
      
      // Ensure userId matches on create
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Nested sub-collections inherit story ownership check
      match /chapters/{chapterId} {
        allow read, write: if isStoryOwner(storyId);
      }
      match /notes/{noteId} {
        allow read, write: if isStoryOwner(storyId);
      }
      match /beats/{beatId} {
        allow read, write: if isStoryOwner(storyId);
      }
      match /characters/{characterId} {
        allow read, write: if isStoryOwner(storyId);
      }
      match /locations/{locationId} {
        allow read, write: if isStoryOwner(storyId);
      }
    }
  }
}
